{
  "name": "oando-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "vercel:preview": "vercel --yes",
    "release:gate": "npm run lint:secrets && npm run lint && npm run typecheck && npm run test && npm run build && npm run test:a11y && npm run test:e2e:nav && npm run test:planner-catalog && npm run test:coverage:planner && npm run test:coverage:site",
    "lint:secrets": "secretlint \"**/*\"",
    "vercel:prod": "npm run release:gate && vercel --prod --yes",
    "seed": "npx tsx scripts/seed.ts",
    "seed:direct": "npx tsx scripts/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint -c config/build/eslint.config.mjs app components features lib tests --max-warnings=0",
    "test": "vitest run",
    "test:layout:check": "node scripts/check-test-layout.mjs",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:planner": "vitest run --coverage",
    "test:coverage:site": "vitest run --coverage --config vitest.site.config.ts",
    "test:features": "vitest run",
    "test:planner": "vitest run planner",
    "test:planner:watch": "vitest planner",
    "test:unit": "vitest run --exclude **/planner*",
    "test:planner-catalog": "playwright test -c config/build/playwright.config.ts tests/planner-catalog.spec.ts tests/planner-guest-workspace.spec.ts tests/planner-custom-tools.spec.ts tests/planner-chrome.spec.ts",
    "test:planner-catalog:watch": "playwright test -c config/build/playwright.config.ts tests/planner-catalog.spec.ts --ui",
    "catalog:ingest": "tsx scripts/ingest-planner-catalog.ts",
    "catalog:blocks:qa": "tsx scripts/generate_blocks.ts",
    "catalog:qa:sheet": "tsx scripts/render-catalog-qa-sheet.ts",
    "catalog:organize:dry": "tsx scripts/organize-catalog-images.ts --dry-run",
    "catalog:organize:apply": "tsx scripts/organize-catalog-images.ts --apply",
    "catalog:organize:sync": "tsx scripts/organize-catalog-images.ts --sync-db --sync-catalog",
    "supabase:assets:arrange": "tsx scripts/arrange_supabase_catalog_assets.ts",
    "audit:products:quality": "npx tsx scripts/audit-product-quality.ts",
    "test:browsers:install": "npx playwright install chromium",
    "test:auth:seed-users": "npx tsx scripts/ensureAuthTestUsers.ts",
    "test:auth:env": "npx tsx scripts/checkAuthEnv.ts",
    "test:auth:env-check": "npm run test:auth:seed-users && npm run test:auth:env",
    "test:e2e:nav": "playwright test -c config/build/playwright.config.ts tests/site-navigation-smoke.spec.ts tests/navigation-smoke.spec.ts",
    "test:a11y": "playwright test -c config/build/playwright.config.ts tests/accessibility.spec.ts",
    "alt:sync:dry": "tsx scripts/sync-missing-alt-text.ts",
    "alt:sync:apply": "tsx scripts/sync-missing-alt-text.ts --apply",
    "supabase:backup": "npx tsx scripts/backup_supabase.ts",
    "audit:supabase:catalog": "npx tsx scripts/audit_supabase_catalog.ts",
    "audit:supabase:admin": "npx tsx scripts/audit_supabase_admin.ts",
    "db:types": "npx -y supabase gen types --linked --schema public > config/database/types/database.types.ts",
    "db:types:admin": "npx tsx scripts/db_gen_admin_types.ts",
    "db:advisors": "npx tsx scripts/db_advisors.ts",
    "db:advisors:security": "npx tsx scripts/db_advisors.ts --security",
    "db:advisors:performance": "npx tsx scripts/db_advisors.ts --performance",
    "db:advisors:admin": "npx tsx scripts/db_advisors_admin.ts",
    "db:backup-dropped": "npx tsx scripts/db_backup_dropped_tables.ts",
    "db:test": "npx tsx scripts/db_test_connection.ts",
    "db:ensure-plans": "npx tsx scripts/db_ensure_plans_table.ts",
    "db:sync-drizzle": "npx tsx scripts/db_sync_drizzle_schema.ts",
    "backup:sync": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/sync-backup-to-15062026.ps1",
    "backup:sync:watch": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/watch-backup-sync.ps1",
    "backup:sync:install": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/install-backup-sync.ps1",
    "db:apply": "npx tsx scripts/db_apply_migrations.ts",
    "db:apply:admin": "npx tsx scripts/db_apply_migrations.ts --target admin",
    "audit:slug-id": "npx tsx scripts/audit_slug_id_integrity.ts",
    "supabase:backfill:canonical": "npx tsx scripts/backfill_canonical_catalog_metadata.ts",
    "supabase:backfill:images": "npx tsx scripts/backfill_missing_product_images.ts",
    "assets:cdn:sync": "node scripts/syncVendorCdnAssets.mjs",
    "assets:cdn:catalog": "npx tsx scripts/downloadCdnAssets.ts",
    "assets:cdn:audit": "npx tsx scripts/auditCdnAssetFailures.ts",
    "assets:cdn:fix": "npx tsx scripts/auditCdnAssetFailures.ts --apply",
    "assets:cdn:replacements": "npx tsx scripts/auditUnresolvedCdnPaths.ts",
    "assets:r2:create-bucket": "npx tsx scripts/create-bucket.ts",
    "assets:r2:delete-bucket": "npx tsx scripts/deleteR2Bucket.ts",
    "assets:cdn:upload": "npx tsx scripts/uploadCdnAssets.ts",
    "assets:cdn:upload:incremental": "npx tsx scripts/uploadCdnAssets.ts --skip-existing",
    "assets:audit:thirdparty": "python scripts/audit_external_asset_hosts.py --fail-on-hit",
    "audit:hosted:runtime": "node scripts/audit-hosted-runtime.mjs",
    "launch:env": "node scripts/validate-launch-env.mjs",
    "launch:smoke": "node scripts/launch-smoke.mjs",
    "project:render": "node scripts/render_project_docs.mjs",
    "recovery:snapshot": "node scripts/recovery-state.mjs",
    "recovery:watch": "node scripts/recovery-state.mjs --watch --interval=45",
    "recovery:chat-snapshot": "node scripts/chat-snapshot.mjs",
    "recovery:handover": "node scripts/recovery-handover.mjs",
    "scan:secrets": "node scripts/scan_secrets.mjs",
    "tree:csv": "node scripts/generate-tree.js",
    "tree:xlsx": "node scripts/generate-tree.js && node scripts/format-dir-tree-xlsx.mjs",
    "// docs:* scripts removed 2026-06-18 (plans/ + docs/ archived per user 'delete all plans and docs' + 'archive it'). Focus on canvas replacement dev.": ""
  },
