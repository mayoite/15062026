{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "tsBuildInfoFile": "../../results/typescript/features.tsbuildinfo"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "apps/site/**/*.ts",
    "apps/site/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "config/database/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "platform/supabase/functions/**",
    "tests/**/*.spec.ts",
    "tests/**/*.spec.tsx",
    "scripts/**"
  ]
}
