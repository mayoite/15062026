{
  "extends": "../config/build/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/types/*": ["../config/database/types/*"],
      "@/app/*": ["../app/*"],
      "@/components/*": ["../components/*"],
      "@/lib/site-data/*": ["../lib/site-data/*"],
      "@/features/*": ["../features/*"],
      "@/lib/*": ["../lib/*"],
      "@/*": ["../*"]
    },
    "types": ["node", "react", "react-dom", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
